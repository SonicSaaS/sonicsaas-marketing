NEXT_PUBLIC_APP_URL=https://app.sonicsaas.com

# Cloudflare Turnstile (CAPTCHA) - get from https://dash.cloudflare.com/turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY is set in Azure Function app settings, not here

# Cloudflare Web Analytics - get from https://dash.cloudflare.com/web-analytics
NEXT_PUBLIC_CF_ANALYTICS_TOKEN=

# Sentry — error tracking (optional, free tier)
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=production
